# ------ All vars must be prefixed VITE_ to be exposed to the browser ------ 

# --- Devnet (testing) ---
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# Relay is proxied through Vite dev server (/cloak-relay → https://api.devnet.cloak.ag)
# to avoid CORS. Override with the real URL for production deploys.
# VITE_CLOAK_RELAY_URL=https://api.devnet.cloak.ag

# --- Mainnet (production) ---
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# VITE_CLOAK_RELAY_URL=https://api.cloak.ag
