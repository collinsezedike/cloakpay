# ------ All vars must be prefixed VITE_ to be exposed to the browser ------

# --- Devnet (testing) ---
# Recommended: use a private RPC with CORS support so the browser connects directly
# (no proxy = no socket hang-ups = blockhash doesn't expire mid-transaction).
# Free devnet key: https://helius.dev → New Project → Devnet endpoint
VITE_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Without a private key, the app falls back to a Vite proxy of api.devnet.solana.com,
# which is less reliable under load.

# Relay is proxied through Vite dev server (/cloak-relay → https://api.devnet.cloak.ag)
# to avoid CORS. Override with the real URL for production deploys.
# VITE_CLOAK_RELAY_URL=https://api.devnet.cloak.ag

# Range.org Risk API key — required for the Ed25519 sanctions check instruction.
# Create one at https://range.org with the Risk API scope.
VITE_RANGE_API_KEY=your_range_api_key_here

# --- Mainnet (production) ---
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# VITE_CLOAK_RELAY_URL=https://api.cloak.ag
